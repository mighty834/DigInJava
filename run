#!/bin/zsh
resultDir="./classes/"

function preCompile {
	javac -classpath . -d $resultDir ./engine/ClassGenerator.java
	java  -classpath $resultDir engine.ClassGenerator
}

function compile {
	javac -classpath . -d $resultDir ./**/*.java
}

function run {
	java -classpath $resultDir engine.Commander $*
}

preCompile
compile
run $*

